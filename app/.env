# ====================================
# IA Juridica - Configuracao de Ambiente
# ====================================

# Ambiente
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-secret-key-mude-em-producao-2024

# Database (SQLite para dev local, PostgreSQL para producao)
# DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@localhost:5432/ia_juridica

# OpenAI - OBRIGATORIO para funcionalidades de IA
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Modelo OpenAI (padrão: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
OPENAI_SEARCH_MODEL=gpt-4o-mini

# CNJ DataJud
# Chave pública disponível em: https://datajud-wiki.cnj.jus.br/api-publica/acesso
CNJ_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==
CNJ_API_URL=https://api-publica.datajud.cnj.jus.br
CNJ_TIMEOUT=30

# WhatsApp (Evolution API)
# URL da instância Evolution API (Docker local: http://host.docker.internal:8083)
WHATSAPP_API_URL=http://host.docker.internal:8083
# Chave de autenticação da Evolution API (definida ao criar a instância)
WHATSAPP_API_KEY=429683C4C977415CAAFCCE10F7D57E11
WHATSAPP_INSTANCE_NAME=ia-juridica

# Apache Airflow
# URL do Airflow (Docker Compose interno: http://airflow-webserver:8080)
AIRFLOW_URL=http://airflow-webserver:8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin

# Flask Frontend
FLASK_SECRET_KEY=flask-dev-secret-key-2024
FLASK_DEBUG=true
API_BASE_URL=http://localhost:8000/api

# CORS
ALLOWED_ORIGINS=["http://localhost:5000","http://localhost:8000","http://127.0.0.1:5000","http://127.0.0.1:8000"]
